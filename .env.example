# Database — use a SEPARATE Supabase/PostgreSQL database, NOT the same DB as softshape-backend
DATABASE_URL=postgresql://user:password@host:5432/softshape_saas?schema=public
DIRECT_URL=postgresql://user:password@host:5432/softshape_saas

# Server
PORT=4000
NODE_ENV=development

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_random_secret_here
JWT_EXPIRES_IN=30d

# Razorpay — get from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://yourdomain.vercel.app,https://softshape.ai

# Email (optional — for OTP verification). Use Gmail app password or Resend.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@softshape.ai

# The existing restaurant backend URL (for linking tenant dashboards)
RESTAURANT_BACKEND_URL=https://softshape-backend.onrender.com
