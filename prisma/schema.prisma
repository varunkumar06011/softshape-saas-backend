generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Owner {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  phone              String
  passwordHash       String
  restaurantName     String
  city               String
  slug               String    @unique
  plan               String    @default("STARTER")
  planPaidAt         DateTime?
  planExpiresAt      DateTime?
  isActive           Boolean   @default(false)
  menuUploadedAt     DateTime?
  onboardingStep     String    @default("REGISTERED")
  razorpayCustomerId String?
  logoUrl            String?
  gstin              String?
  address            String?
  cuisineType        String?
  seatingCapacity    Int?
  restaurantId       String?   @unique
  swiggyStoreId      String?
  zomatoOutletId     String?
  urbanpiperLinked   Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  sections     TenantSection[]
  stations     CashierStation[]
  captains     CaptainLogin[]
  adminCred    AdminCredential?
  payments     Payment[]
  menuItems    TenantMenuItem[]
  orders       Order[]
  onlineOrders OnlineOrder[]
  auditLogs    AuditLog[]

  @@index([slug])
  @@index([email])
}

model TenantSection {
  id            String   @id @default(cuid())
  ownerId       String
  owner         Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name          String
  tableCount    Int      @default(4)
  tableCapacity Int      @default(4)
  createdAt     DateTime @default(now())

  @@index([ownerId])
}

model CashierStation {
  id           String   @id @default(cuid())
  ownerId      String
  owner        Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  restaurantId String
  stationName  String
  stationType  String   @default("DINING")
  menuFilter   String   @default("FOOD")
  username     String
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@unique([restaurantId, username])
  @@index([restaurantId])
}

model CaptainLogin {
  id           String   @id @default(cuid())
  ownerId      String
  owner        Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  restaurantId String
  captainName  String
  pin          String
  initials     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  @@index([restaurantId])
}

model AdminCredential {
  id           String   @id @default(cuid())
  ownerId      String   @unique
  owner        Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  restaurantId String   @unique
  username     String
  passwordHash String
  createdAt    DateTime @default(now())
}

model Payment {
  id                String   @id @default(cuid())
  ownerId           String
  owner             Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  plan              String
  amount            Int
  razorpayOrderId   String   @unique
  razorpayPaymentId String?
  razorpaySignature String?
  status            String   @default("PENDING")
  createdAt         DateTime @default(now())
  paidAt            DateTime?

  @@index([ownerId])
}

model TenantMenuItem {
  id           String   @id @default(cuid())
  ownerId      String
  owner        Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  restaurantId String
  itemName     String
  category     String
  price        Float
  menuType     String   @default("FOOD")
  isVeg        Boolean  @default(true)
  variants     String?
  isActive     Boolean  @default(true)
  imageUrl     String?
  isSpecial    Boolean  @default(false)
  specialNote  String?
  station      String   @default("KITCHEN")
  createdAt    DateTime @default(now())

  @@index([restaurantId])
  @@index([ownerId])
  @@index([isSpecial])
}

model Order {
  id            String      @id @default(cuid())
  ownerId       String
  owner         Owner       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  restaurantId  String
  tableId       String
  tableName     String
  section       String
  captainId     String?
  captainName   String?
  status        String      @default("OPEN")
  source        String      @default("DINE_IN")
  parentOrderId String?
  billNumber    String?
  billPrintedAt DateTime?
  subtotal      Float       @default(0)
  cgst          Float       @default(0)
  sgst          Float       @default(0)
  total         Float       @default(0)
  paymentMode   String?
  paidAt        DateTime?
  note          String?
  items         OrderItem[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([restaurantId])
  @@index([ownerId])
  @@index([tableId, status])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String?
  name      String
  category  String
  price     Float
  qty       Int
  menuType  String  @default("FOOD")
  isVeg     Boolean @default(true)
  note      String?
  kotSent   Boolean @default(false)
  kotSentAt DateTime?

  @@index([orderId])
}

model OnlineOrder {
  id              String   @id @default(cuid())
  ownerId         String
  owner           Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  restaurantId    String
  platform        String
  platformOrderId String   @unique
  customerName    String
  customerPhone   String?
  items           Json
  subtotal        Float
  taxes           Float
  total           Float
  status          String   @default("NEW")
  autoAccepted    Boolean  @default(false)
  acceptedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([restaurantId])
  @@index([ownerId])
}

model AuditLog {
  id                    String   @id @default(cuid())
  ownerId               String
  owner                 Owner    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  restaurantId          String
  action                String
  targetId              String
  targetType            String
  performedBy           String
  performedByUsername   String
  details               Json?
  createdAt             DateTime @default(now())

  @@index([restaurantId])
  @@index([ownerId])
}

model Order {
  id           String    @id @default(cuid())
  restaurantId String
  tableId      String?
  items        String    @default("[]")
  status       String    @default("RUNNING")
  source       String    @default("DINE_IN")
  paymentMode  String?
  subtotal     Float?
  cgst         Float?
  sgst         Float?
  total        Float?
  paidAt       DateTime?
  clientId     String?   @unique
  deviceId     String?
  syncedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([restaurantId])
  @@index([status])
  @@index([clientId])
  @@index([paidAt])
}
